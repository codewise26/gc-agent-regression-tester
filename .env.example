# Copy to .env and fill in your values:
#   cp .env.example .env

# --- Genesys Cloud Web Messaging (required for CLI) ---
GC_REGION=mypurecloud.com
GC_DEPLOYMENT_ID=YOUR_DEPLOYMENT_ID
GC_ORIGIN=https://apps.mypurecloud.com

# --- Genesys Cloud Platform API (required for conversation cleanup) ---
GC_CLIENT_ID=your_oauth_client_id
GC_CLIENT_SECRET=your_oauth_client_secret

# --- Ollama (required for CLI) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Test runner tuning ---
GC_TESTER_DEFAULT_ATTEMPTS=5
GC_TESTER_MAX_TURNS=20
GC_TESTER_RESPONSE_TIMEOUT=30
GC_TESTER_SUCCESS_THRESHOLD=0.8

# --- Optional ---
# GC_TESTER_CONVERSATIONS_FILE=.gc-tester/active_conversations.json
# GC_TESTER_WEB_PORT=8899
# GC_TESTER_CONFIG_FILE=config.yaml
# FLASK_SECRET_KEY=change-me-in-production
